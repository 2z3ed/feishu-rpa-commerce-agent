# 项目配置基线：交接 / 复现 / 验收以本文件为准；真实密钥与私有值只填本机 .env，勿提交。
APP_NAME=feishu-rpa-commerce-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TZ=Asia/Shanghai
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=feishu_rpa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# 本地开发可选：使用 SQLite 替代 PostgreSQL（与正式栈一致时请保持 false）
USE_SQLITE=false

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# RAG (optional; default off).Collection 需含向量字段 embedding（维数=RAG_EMBEDDING_DIM）及标量/动态字段：
# use_case ∈ command_interpretation | rule_augment | failure_explanation；category ∈ sop|faq|case|error_resolution|rule；text；intent_hint（建议填写）
# command_interpretation：入库 intent_hint 应对齐业务 intent（如 product.query_sku_status / product.update_price），否则易串场；图谱中 unknown 不跑 command_interpretation（避免与失败链抢占），失败增强见 finalize 的 failure_explanation
ENABLE_RAG=false
MILVUS_COLLECTION_NAME=
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0
RAG_EMBEDDING_DIM=128
RAG_USE_CASE_ENABLED_COMMAND_INTERPRETATION=true
RAG_USE_CASE_ENABLED_RULE_AUGMENT=true
RAG_USE_CASE_ENABLED_FAILURE_EXPLANATION=true

# Feishu
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BOT_NAME=commerce-agent-bot
# 群聊 @ 机器人判定：与 im.message.receive_v1 里 mentions[].id.open_id 一致（非 FEISHU_APP_ID）
FEISHU_BOT_OPEN_ID=

# Feishu Bitable (optional one-way APPEND ledger; add columns: task_id,target_task_id,intent_code,task_type,
# intent_text,status,sku,product_name,inventory,price,platform,requires_confirmation,confirmation_status,
# created_at,updated_at,result_summary,error_message)
ENABLE_FEISHU_BITABLE_WRITE=false
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# Query mode (dev-only)
PRODUCT_QUERY_SKU_DEFAULT_EXECUTION_MODE=mock
PRODUCT_QUERY_SKU_DEFAULT_PLATFORM=sandbox
PRODUCT_QUERY_SKU_API_BASE_URL=internal://sandbox
PRODUCT_QUERY_SKU_API_TIMEOUT_MS=2000
ENABLE_INTERNAL_SANDBOX_API=true
# 兼容旧名，与 PRODUCT_QUERY_SKU_API_BASE_URL 默认相同；新配置请用后者
PRODUCT_QUERY_SKU_SANDBOX_BASE_URL=internal://sandbox

# Provider auth placeholders (dev/example only)
WOO_API_TOKEN=
WOO_API_KEY=
WOO_API_SECRET=
ODOO_SESSION_ID=
ODOO_DB=

# Woo read-only prep (no real production request in current phase)
WOO_BASE_URL=
WOO_API_VERSION_PREFIX=wp-json/wc/v3
WOO_AUTH_MODE=token_header
WOO_READONLY_TIMEOUT_MS=2000
WOO_ALLOW_INTERNAL_SANDBOX_FALLBACK=true
WOO_ENABLE_READONLY_DRY_RUN=false
WOO_ENABLE_READONLY_DRY_RUN_FALLBACK=true
WOO_ENABLE_READONLY_LIVE_PROBE=false
WOO_LIVE_BASE_URL=
WOO_LIVE_TIMEOUT_MS=2000

# RPA — dev only; post-confirm execution for product.update_price (not shown to Feishu users)
# mock = existing mock_repo; rpa = LocalFakeRpaRunner + evidence under RPA_EVIDENCE_BASE_DIR
PRODUCT_UPDATE_PRICE_CONFIRM_EXECUTION_BACKEND=mock
RPA_EVIDENCE_BASE_DIR=data/rpa_evidence
RPA_UPDATE_PRICE_TIMEOUT_S=180
RPA_UPDATE_PRICE_VERIFY_MODE=basic
RPA_UPDATE_PRICE_DRY_RUN=false
RPA_RUNNER_NAME=local_fake
RPA_FAKE_RUNNER_FORCE_FAILURE=false
RPA_API_THEN_RPA_VERIFY_ENABLED=false

# P3.1 — Playwright against local sandbox only (not production)
# local_fake = placeholder PNGs | browser_real = Chromium + /api/v1/internal/rpa-sandbox/update-price
RPA_RUNNER_TYPE=local_fake
RPA_BROWSER_HEADLESS=true
# Worker must reach the same host:port as uvicorn (local dev: 127.0.0.1 + APP_PORT)
RPA_SANDBOX_BASE_URL=http://127.0.0.1:8000
RPA_BROWSER_TIMEOUT_S=30
# Dev: sandbox page force_fail=1 after submit (browser_real only)
RPA_BROWSER_FORCE_FAILURE=false