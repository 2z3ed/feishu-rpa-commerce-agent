# 项目配置基线：交接 / 复现 / 验收以本文件为准；真实密钥与私有值只填本机 .env，勿提交。
APP_NAME=feishu-rpa-commerce-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TZ=Asia/Shanghai
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=feishu_rpa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# 本地开发可选：使用 SQLite 替代 PostgreSQL（与正式栈一致时请保持 false）
USE_SQLITE=false

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# RAG (optional; default off).Collection 需含向量字段 embedding（维数=RAG_EMBEDDING_DIM）及标量/动态字段：
# use_case ∈ command_interpretation | rule_augment | failure_explanation；category ∈ sop|faq|case|error_resolution|rule；text；intent_hint（建议填写）
# command_interpretation：入库 intent_hint 应对齐业务 intent（如 product.query_sku_status / product.update_price），否则易串场；图谱中 unknown 不跑 command_interpretation（避免与失败链抢占），失败增强见 finalize 的 failure_explanation
ENABLE_RAG=false
MILVUS_COLLECTION_NAME=
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0
RAG_EMBEDDING_DIM=128
RAG_USE_CASE_ENABLED_COMMAND_INTERPRETATION=true
RAG_USE_CASE_ENABLED_RULE_AUGMENT=true
RAG_USE_CASE_ENABLED_FAILURE_EXPLANATION=true

# Feishu
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BOT_NAME=commerce-agent-bot
# 群聊 @ 机器人判定：与 im.message.receive_v1 里 mentions[].id.open_id 一致（非 FEISHU_APP_ID）
FEISHU_BOT_OPEN_ID=

# Feishu Bitable (optional one-way APPEND ledger; add columns: task_id,target_task_id,intent_code,task_type,
# intent_text,status,sku,product_name,inventory,price,platform,requires_confirmation,confirmation_status,
# created_at,updated_at,result_summary,error_message)
ENABLE_FEISHU_BITABLE_WRITE=false
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# Query mode (dev-only)
PRODUCT_QUERY_SKU_DEFAULT_EXECUTION_MODE=mock
PRODUCT_QUERY_SKU_ENABLE_REAL_ADMIN_READONLY=false
PRODUCT_QUERY_SKU_DEFAULT_PLATFORM=sandbox
PRODUCT_QUERY_SKU_API_BASE_URL=internal://sandbox
PRODUCT_QUERY_SKU_API_TIMEOUT_MS=2000
ENABLE_INTERNAL_SANDBOX_API=true
# 兼容旧名，与 PRODUCT_QUERY_SKU_API_BASE_URL 默认相同；新配置请用后者
PRODUCT_QUERY_SKU_SANDBOX_BASE_URL=internal://sandbox

# Provider auth placeholders (dev/example only)
WOO_API_TOKEN=
WOO_API_KEY=
WOO_API_SECRET=
ODOO_SESSION_ID=
ODOO_DB=

# Woo read-only prep (no real production request in current phase)
WOO_BASE_URL=
WOO_API_VERSION_PREFIX=wp-json/wc/v3
WOO_AUTH_MODE=token_header
WOO_READONLY_TIMEOUT_MS=2000
WOO_ALLOW_INTERNAL_SANDBOX_FALLBACK=true
WOO_ENABLE_READONLY_DRY_RUN=false
WOO_ENABLE_READONLY_DRY_RUN_FALLBACK=true
WOO_ENABLE_READONLY_LIVE_PROBE=false
WOO_LIVE_BASE_URL=
WOO_LIVE_TIMEOUT_MS=2000

# RPA — dev only; post-confirm execution for product.update_price (not shown to Feishu users)
# mock | rpa | api_then_rpa_verify
# api_then_rpa_verify = 先 product_repo 受控写入，再 list_detail 只读回页面与 API 比对（需 browser_real + RPA_TARGET_ENV=list_detail）
PRODUCT_UPDATE_PRICE_CONFIRM_EXECUTION_BACKEND=mock
RPA_EVIDENCE_BASE_DIR=data/rpa_evidence
RPA_UPDATE_PRICE_TIMEOUT_S=180
RPA_UPDATE_PRICE_VERIFY_MODE=basic
RPA_UPDATE_PRICE_DRY_RUN=false
RPA_RUNNER_NAME=local_fake
RPA_FAKE_RUNNER_FORCE_FAILURE=false
# 已废弃：请用 PRODUCT_UPDATE_PRICE_CONFIRM_EXECUTION_BACKEND=api_then_rpa_verify
RPA_API_THEN_RPA_VERIFY_ENABLED=false
# P3.4 仅用于验收「API 成功但页面与 API 不一致」：为 true 时受控页 URL 故意带错 current_price
RPA_API_THEN_RPA_VERIFY_FORCE_PAGE_MISMATCH=false

# P3.1 — Playwright against local sandbox only (not production)
# local_fake = placeholder PNGs | browser_real = Chromium + /api/v1/internal/rpa-sandbox/update-price
RPA_RUNNER_TYPE=local_fake
RPA_BROWSER_HEADLESS=true
# Worker must reach the same host:port as uvicorn (local dev: 127.0.0.1 + APP_PORT)
RPA_SANDBOX_BASE_URL=http://127.0.0.1:8000
RPA_BROWSER_TIMEOUT_S=30
# Dev: sandbox page force_fail=1 after submit (browser_real only)
RPA_BROWSER_FORCE_FAILURE=false

# P3.3 — list → detail → edit (internal); empty base = RPA_SANDBOX_BASE_URL
RPA_LIST_DETAIL_BASE_URL=
# none | sku_missing_in_list | detail_page_not_found | save_button_disabled | save_error
# 受控 hub 页「商品·目录」链接会携带本模式；工作台链接仍只用 admin_like 的 failure 集合（未知则 none）
RPA_LIST_DETAIL_FORCE_FAILURE_MODE=none

# P3.2 / P3.3 — browser_real: sandbox | admin_like (hub+工作台) | list_detail (hub+列表+详情)
RPA_TARGET_ENV=sandbox
# Optional; empty = same as RPA_SANDBOX_BASE_URL
RPA_ADMIN_LIKE_BASE_URL=
# admin_like only: none | sku_missing | save_error | save_disabled
RPA_ADMIN_LIKE_FORCE_FAILURE_MODE=none

# P4.1 / P4.2 — 真实后台接入前置 + 只读导航读回（不自动登录、浏览器内不接保存/生产写）
# internal_controlled = 现有 sandbox / admin_like / list_detail
# real_admin_prepared = 配置 + readiness + 会话注入 + home→catalog→detail 只读读回（P4.2）
RPA_TARGET_PROFILE=internal_controlled
# 以下仅在 RPA_TARGET_PROFILE=real_admin_prepared 时参与 readiness（缺任一项 → not_ready）
RPA_REAL_ADMIN_BASE_URL=
RPA_REAL_ADMIN_HOME_PATH=
RPA_REAL_ADMIN_CATALOG_PATH=
# 须包含字面量 {sku}，例如 /admin/product?sku={sku}
RPA_REAL_ADMIN_DETAIL_PATH_TEMPLATE=
# 列表/目录 SKU 检索参数名（文档 + 校验非空）；会拼到 CATALOG_PATH 后 ?或& 上
RPA_REAL_ADMIN_SKU_SEARCH_PARAM=
# 可选：说明路径规则、编码方式等
RPA_REAL_ADMIN_SKU_SEARCH_NOTES=
# P4.2 只读读回：CSS 选择器（真实后台按 DOM 配置；本地验收可指向下方 internal mirror）
RPA_REAL_ADMIN_DETAIL_PRICE_SELECTOR=
RPA_REAL_ADMIN_CATALOG_EMPTY_SELECTOR=
# 可选：页面 SKU 文本；留空则用「当前 URL 是否含 SKU」推断命中
RPA_REAL_ADMIN_DETAIL_SKU_SELECTOR=
RPA_REAL_ADMIN_DETAIL_STATUS_SELECTOR=
RPA_REAL_ADMIN_DETAIL_MESSAGE_SELECTOR=
RPA_REAL_ADMIN_DETAIL_PRODUCT_NAME_SELECTOR=
# api_then_rpa_verify 比对用；留空则 page_new_price_field 回退为请求的 target_price
RPA_REAL_ADMIN_DETAIL_NEW_PRICE_SELECTOR=
# P4.5 写链：新价格输入/保存按钮/保存结果（均为 CSS 选择器）
RPA_REAL_ADMIN_DETAIL_SAVE_BUTTON_SELECTOR=
RPA_REAL_ADMIN_DETAIL_SAVE_RESULT_SELECTOR=
# P4.6 写后比对容差（默认 0.009）
RPA_REAL_ADMIN_PRICE_COMPARE_TOLERANCE=0.009
# 会话注入（二选一或组合）：Cookie 串 与/或 JSON 头（合并进 Playwright extra_http_headers）
RPA_REAL_ADMIN_SESSION_COOKIE=
# JSON 对象，如 {"Authorization":"Bearer xxx"}
RPA_REAL_ADMIN_SESSION_HEADERS_JSON=
# 任意 browser_real 额外头（JSON）；与上面合并
RPA_BROWSER_EXTRA_HTTP_HEADERS_JSON=
# 可选：{"localStorage":{"k":"v"},"sessionStorage":{}}，在首次导航前注入
RPA_BROWSER_STORAGE_INIT_JSON=
# 可选：对 HOME URL 做安全 GET 探活（默认关）
RPA_REAL_ADMIN_READINESS_HTTP_PROBE=false
RPA_REAL_ADMIN_READINESS_PROBE_TIMEOUT_S=5

# P4.2 本地 mirror（ENABLE_INTERNAL_SANDBOX_API=true 时）：把 BASE 指到本机 API，路径示例如下（与 APP_PORT 一致）
# RPA_TARGET_PROFILE=real_admin_prepared
# RPA_REAL_ADMIN_BASE_URL=http://127.0.0.1:8000
# RPA_REAL_ADMIN_HOME_PATH=/api/v1/internal/rpa-real-admin-mirror/home
# RPA_REAL_ADMIN_CATALOG_PATH=/api/v1/internal/rpa-real-admin-mirror/catalog
# RPA_REAL_ADMIN_DETAIL_PATH_TEMPLATE=/api/v1/internal/rpa-real-admin-mirror/detail/{sku}
# RPA_REAL_ADMIN_SKU_SEARCH_PARAM=sku
# RPA_REAL_ADMIN_DETAIL_PRICE_SELECTOR=[data-testid="real-admin-current-price"]
# RPA_REAL_ADMIN_CATALOG_EMPTY_SELECTOR=[data-testid="real-admin-catalog-empty"][data-visible="1"]
# RPA_REAL_ADMIN_DETAIL_NEW_PRICE_SELECTOR=[data-testid="real-admin-new-price"]
# RPA_REAL_ADMIN_DETAIL_SAVE_BUTTON_SELECTOR=[data-testid="real-admin-save-btn"]
# RPA_REAL_ADMIN_DETAIL_SAVE_RESULT_SELECTOR=[data-testid="real-admin-save-result"][data-visible="1"]
# RPA_REAL_ADMIN_SESSION_COOKIE=dev_mirror=1
# 代表性失败：目录无结果可把 SKU 设为 __MIRROR_EMPTY__，或 catalog 路径加 &mirror_empty=1
# detail 选择器缺失：/api/v1/internal/rpa-real-admin-mirror/detail/A001?mirror_fail=missing_price
# P4.5 写链代表性失败：
# - save_disabled：/api/v1/internal/rpa-real-admin-mirror/detail/A001?mirror_fail=save_disabled
# - post_save_price_mismatch：/api/v1/internal/rpa-real-admin-mirror/detail/A001?mirror_fail=post_save_price_mismatch
# - submit_no_effect：/api/v1/internal/rpa-real-admin-mirror/detail/A001?mirror_fail=submit_no_effect

# P7.0 / P7.1 — Yingdao local bridge (PoC; non-production)
# internal_sandbox | yingdao_bridge
ODOO_ADJUST_INVENTORY_CONFIRM_EXECUTION_BACKEND=internal_sandbox
YINGDAO_BRIDGE_BASE_URL=http://127.0.0.1:17891
YINGDAO_BRIDGE_TIMEOUT_S=30
YINGDAO_BRIDGE_ENVIRONMENT=local_poc
YINGDAO_BRIDGE_INPUT_DIR=tmp/yingdao_bridge/inbox
YINGDAO_BRIDGE_OUTPUT_DIR=tmp/yingdao_bridge/outbox
YINGDAO_BRIDGE_WAIT_TIMEOUT_S=20
YINGDAO_BRIDGE_POLL_INTERVAL_MS=200

# file_exchange | controlled_page
YINGDAO_BRIDGE_EXECUTION_MODE=file_exchange
YINGDAO_CONTROLLED_PAGE_BASE_URL=http://127.0.0.1:8000
YINGDAO_CONTROLLED_PAGE_PROFILE=internal_inventory_adjust_v1